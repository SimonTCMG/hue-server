# ─── Hue — Environment Variables ──────────────────────────────────────────
# Copy this file to .env for local development.
# Set all variables in Railway: Project → Variables.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# MailerLite API key — get from app.mailerlite.com → Integrations → API
# IMPORTANT: Daily personalised emails require the MailerLite transactional
# email addon (Email API). Check app.mailerlite.com → Email API.
# Subscriber management (registration) works on the free plan.
MAILERLITE_API_KEY=

# From address for daily emails — must be authenticated in MailerLite
FROM_EMAIL=hello@myhue.co

# Invite token for beta registration — share as myhue.co/register?invite=TOKEN
# Change this to something less guessable before sharing the beta link.
INVITE_TOKEN=BETA2026

# Set to "production" on Railway — enables secure cookies
NODE_ENV=production

# Port (Railway sets this automatically — only needed locally if 3001 is taken)
PORT=3001
